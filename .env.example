# Core app
NODE_ENV=production
PORT=3000
SITE_URL=https://example.com
NEXT_PUBLIC_SITE_URL=https://example.com
GOOGLE_SITE_VERIFICATION=replace_with_google_verification_token

# Auth service
AUTH_PORT=3001
BOT_TOKEN=replace_with_telegram_bot_token
CORS_ORIGINS=https://example.com,https://www.example.com

# 1C / backend proxy
ONEC_BASE_URL=https://your-1c-endpoint.example.com
ONEC_AUTH_HEADER=Basic replace_with_base64_login_password
NP_API_KEY=replace_with_nova_poshta_api_key

# LiqPay
LIQPAY_PUBLIC_KEY=replace_with_liqpay_public_key
LIQPAY_PRIVATE_KEY=replace_with_liqpay_private_key
NEXT_PUBLIC_LIQPAY_PUBLIC_KEY=replace_with_liqpay_public_key
NEXT_PUBLIC_LIQPAY_RESULT_URL=https://example.com/success
NEXT_PUBLIC_LIQPAY_SERVER_URL=https://example.com/api/liqpay/callback

# Telegram widget (client-side)
NEXT_PUBLIC_TELEGRAM_BOT_NAME=StormStoreAvto_bot
NEXT_PUBLIC_TELEGRAM_AUTH_URL=https://example.com/auth/telegram

# Local development examples:
# NEXT_PUBLIC_TELEGRAM_AUTH_URL=http://localhost:3001/auth/telegram
# NEXT_PUBLIC_LIQPAY_RESULT_URL=http://localhost:3000/success
# NEXT_PUBLIC_LIQPAY_SERVER_URL=http://localhost:3000/api/liqpay/callback

# Firebase (client config)
NEXT_PUBLIC_FIREBASE_API_KEY=replace_with_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=replace_with_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=replace_with_app_id
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=replace_with_measurement_id
