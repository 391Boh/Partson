# Core app
# Do not set NODE_ENV in .env.local for Next.js dev mode.
# Next sets NODE_ENV automatically for `next dev` and `next build`.
PORT=3000
SITE_URL=https://example.com
NEXT_PUBLIC_SITE_URL=https://example.com
GOOGLE_SITE_VERIFICATION=replace_with_google_verification_token
# Google Places API — для автооновлення рейтингу з Google Business (раз на добу)
# Place ID: знайти на https://developers.google.com/maps/documentation/places/web-service/place-id
# API key: https://console.cloud.google.com → Enable "Places API"
GOOGLE_MAPS_API_KEY=
GOOGLE_PLACE_ID=
# Analytics: use GTM as the single loader (recommended). Configure the G- ID
# inside that container. If GTM is empty, NEXT_PUBLIC_GOOGLE_ANALYTICS_ID is
# used as a direct Google tag fallback. Do not run both tags independently.
NEXT_PUBLIC_GOOGLE_TAG_MANAGER_ID=GTM-XXXXXXX
NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX
# Local analytics is disabled by default to keep production data clean.
NEXT_PUBLIC_ANALYTICS_ENABLE_IN_DEVELOPMENT=0
# Enable only while validating events in GA4 DebugView / Tag Assistant.
NEXT_PUBLIC_ANALYTICS_DEBUG=0
NEXT_ALLOWED_DEV_ORIGINS=
NEXT_DISABLE_TURBOPACK_DEV_CACHE=0

# SEO / sitemap
SITEMAP_MAX_GROUP_PAGES=5000
SITEMAP_MAX_MANUFACTURER_PAGES=5000
# Static params: how many pages to pre-render at build time (matches what's
# actually in the sitemap, so a visitor from Google always hits an already-
# built page instead of paying the first-request ISR cost).
# 0 = disabled (ISR on first visit); safe default for initial deploy.
# Current real sitemap sizes (2026-07): 312 manufacturers, 14 top-level
# groups, 151 group/subgroup items — small enough to fully pre-render.
#   SEO_GROUP_STATIC_PARAMS_LIMIT=20         (14 real top-level groups + headroom)
#   SEO_GROUP_ITEM_STATIC_PARAMS_LIMIT=200   (151 real subgroup/leaf pages + headroom; each calls 1C at build)
#   SEO_MANUFACTURER_STATIC_PARAMS_LIMIT=350 (312 real manufacturer pages + headroom; each calls 1C at build)
# Raise limits only after confirming 1C API responds in < 1 s under build load.
SEO_GROUP_STATIC_PARAMS_LIMIT=20
SEO_GROUP_ITEM_STATIC_PARAMS_LIMIT=200
SEO_MANUFACTURER_STATIC_PARAMS_LIMIT=350
# Pre-generate product pages at build time using sitemap data.
# Default 0 = disabled (ISR on first visit). Safe to enable when:
#   - total product count is < 10 000 (one full sitemap pass is fast)
#   - 1C API responds in < 1 s (each pre-generated page calls 1C at build time)
# The priced-product sitemap currently has 1297 entries, but getprod-style
# per-page lookups are limited to 2 concurrent 1C requests (see oneC.js) —
# pre-rendering all 1297 at build could add many minutes. Start at the
# documented first-deploy recommendation and raise gradually:
#   SEO_PRODUCT_STATIC_PARAMS_LIMIT=500
# Increase toward 1297 (full sitemap coverage) only after build time is
# confirmed acceptable (< 15 min) — the rest still render fine via ISR.
# NOTE: getAllProductSitemapEntries() fetches the FULL catalog; keep limit low if
# the catalog is very large, or leave 0 and rely on ISR with revalidate=900.
SEO_PRODUCT_STATIC_PARAMS_LIMIT=500
PRODUCT_SITEMAP_CHUNK_SIZE=2000
PRODUCT_SITEMAP_MAX_ITEMS=50000
PRODUCT_SITEMAP_MAX_PAGES=1000
PRODUCT_SITEMAP_PAGE_SIZE=80
# Only list car models in auto-sitemap.xml that actually have matching
# products (checked via `npm run generate:auto-model-sitemap`, part of
# `npm run build`/`build:full`). Snapshot path/concurrency rarely need
# changing — defaults are sane for ~60 brands / a few thousand models.
# AUTO_MODEL_SITEMAP_SNAPSHOT_PATH=.cache/auto-model-sitemap.json
# AUTO_MODEL_SITEMAP_BRAND_CONCURRENCY=8
# Pre-render /auto/[brand] and /auto/[brand]/[model] at build, same idea as
# the other SEO_*_STATIC_PARAMS_LIMIT vars above.
# - Brand pages (62 total) are cheap — the brand list is static data, no 1C
#   call needed just to enumerate it — safe to cover in full.
# - Model pages only pre-render models already verified (by
#   generate:auto-model-sitemap) to have real products — currently 1113 of
#   them — but EACH one costs a real getModelGroupBreakdown scan (up to 40
#   paged 1C calls), far heavier than a manufacturer/group page. Start small
#   and raise only after confirming build time stays acceptable; the rest
#   still render fine via ISR (revalidate=21600).
SEO_AUTO_BRAND_STATIC_PARAMS_LIMIT=62
SEO_AUTO_MODEL_STATIC_PARAMS_LIMIT=150
# AUTO_MODEL_SITEMAP_CHECK_CONCURRENCY=12

# Auth service
AUTH_PORT=3001
BOT_TOKEN=replace_with_telegram_bot_token
TELEGRAM_BOT_TOKEN=replace_with_telegram_bot_token
CORS_ORIGINS=https://example.com,https://www.example.com
TELEGRAM_WEBHOOK_SECRET=replace_with_random_webhook_secret

# Telegram admin notifications
# Chat id can be your personal Telegram id or a group/channel id.
# Multiple recipients: 123456789,-1001234567890
TELEGRAM_NOTIFY_CHAT_ID=replace_with_admin_chat_id
# Secret token for /api/telegram/notify — prevents external abuse.
# Generate: openssl rand -hex 32
# Must match NEXT_PUBLIC_NOTIFY_SECRET so the browser can send it as a header.
NOTIFY_SECRET=replace_with_random_hex_secret
NEXT_PUBLIC_NOTIFY_SECRET=replace_with_random_hex_secret

# 1C / backend proxy
ONEC_BASE_URL=https://your-1c-endpoint.example.com
ONEC_AUTH_HEADER=Basic replace_with_base64_login_password
ONEC_IMAGE_BATCH_ENDPOINT=getimages
ONEC_PRODUCT_UPDATE_ENDPOINT=edit
NP_API_KEY=replace_with_nova_poshta_api_key

# LiqPay
# Live payments require production LiqPay keys without the sandbox_ prefix.
LIQPAY_PUBLIC_KEY=replace_with_liqpay_public_key
LIQPAY_PRIVATE_KEY=replace_with_liqpay_private_key
LIQPAY_SANDBOX=0
NEXT_PUBLIC_LIQPAY_PUBLIC_KEY=replace_with_liqpay_public_key
NEXT_PUBLIC_LIQPAY_SANDBOX=0
NEXT_PUBLIC_LIQPAY_RESULT_URL=https://example.com/success
NEXT_PUBLIC_LIQPAY_SERVER_URL=https://example.com/api/liqpay/callback

# Telegram widget (client-side)
# New Telegram Login / OIDC flow.
TELEGRAM_CLIENT_ID=replace_with_botfather_client_id
TELEGRAM_CLIENT_SECRET=replace_with_botfather_client_secret
NEXT_PUBLIC_TELEGRAM_CLIENT_ID=replace_with_botfather_client_id
# Add this exact Redirect URI in BotFather Web Login:
# https://example.com/api/telegram/oidc/callback
# Legacy iframe widget fallback.
NEXT_PUBLIC_TELEGRAM_BOT_NAME=StormStoreAvto_bot
NEXT_PUBLIC_TELEGRAM_AUTH_URL=https://example.com/auth/telegram

# Local development examples:
# NEXT_PUBLIC_TELEGRAM_AUTH_URL=http://localhost:3001/auth/telegram
# NEXT_PUBLIC_LIQPAY_RESULT_URL=http://localhost:3000/success
# NEXT_PUBLIC_LIQPAY_SERVER_URL=http://localhost:3000/api/liqpay/callback

# Firebase (client config)
NEXT_PUBLIC_FIREBASE_API_KEY=replace_with_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=replace_with_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=replace_with_app_id
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=replace_with_measurement_id

# Firebase Admin (required for Telegram login custom tokens)
# Option 1: full service account JSON in one line.
FIREBASE_SERVICE_ACCOUNT_KEY={"project_id":"your-project-id","client_email":"firebase-adminsdk@example.iam.gserviceaccount.com","private_key":"-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----\\n"}
# Option 2: separate fields instead of FIREBASE_SERVICE_ACCOUNT_KEY.
FIREBASE_ADMIN_PROJECT_ID=your-project-id
FIREBASE_ADMIN_CLIENT_EMAIL=firebase-adminsdk@example.iam.gserviceaccount.com
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----\\n"

# Admin panel visibility in client UI
# Comma-separated emails that should see the admin panel button.
NEXT_PUBLIC_ADMIN_EMAILS=admin@example.com
