"use client";

import { memo, useEffect, useMemo, useState } from "react";
import { motion } from "framer-motion";
import { Factory, Info, Search } from "lucide-react";
import { brands } from "app/components/brandsData";
import Link from "next/link";
import { useRouter } from "next/navigation";

const viewportConfig = { once: false, amount: 0.35, margin: "0px 0px -6% 0px" };
const backgroundBase = [
  "radial-gradient(circle at 50% -10%, rgba(255,255,255,0.45), transparent 55%)",
  "radial-gradient(circle at 50% 120%, rgba(15,23,42,0.18), transparent 60%)",
  "radial-gradient(circle at 14% 14%, rgba(94,234,212,0.18), transparent 42%)",
  "radial-gradient(circle at 86% 18%, rgba(56,189,248,0.2), transparent 46%)",
  "radial-gradient(circle at 48% 88%, rgba(186,230,253,0.28), transparent 40%)",
  "linear-gradient(180deg, #7d9ec6 0%, #9fbee2 38%, #cfe6fb 70%, #f5faff 100%)",
].join(", ");
const cardBackdrop = (
  <div className="pointer-events-none absolute inset-0">
    <div className="absolute -left-16 top-2 h-72 w-72 rounded-full bg-white/45 blur-[100px]" />
    <div className="absolute right-[-10%] bottom-[-20%] h-96 w-96 rounded-full bg-cyan-200/28 blur-[120px]" />
    <div className="absolute inset-0 bg-gradient-to-b from-white/65 via-white/28 to-white/8" />
  </div>
);

type BrandSearchInputProps = {
  value: string;
  onChange: (value: string) => void;
  brandNames: string[];
};

const BrandSearchInput = memo(
  ({ value, onChange, brandNames }: BrandSearchInputProps) => {
    const [isInputFocused, setIsInputFocused] = useState(false);
    const [animatedPlaceholder, setAnimatedPlaceholder] = useState("");

    useEffect(() => {
      if (!brandNames.length || isInputFocused || value.trim()) {
        setAnimatedPlaceholder("");
        return;
      }
      let active = true;
      let wordIndex = 0;
      let charIndex = 0;
      let direction: "forward" | "back" = "forward";
      let timeoutId: ReturnType<typeof setTimeout>;

      const tick = () => {
        if (!active) return;
        const word = brandNames[wordIndex] || "";

        if (direction === "forward") {
          charIndex = Math.min(word.length, charIndex + 1);
          setAnimatedPlaceholder(word.slice(0, charIndex) || "");
          if (charIndex === word.length) {
            direction = "back";
            timeoutId = setTimeout(tick, 900);
            return;
          }
          timeoutId = setTimeout(tick, 80);
          return;
        }

        charIndex = Math.max(0, charIndex - 1);
        setAnimatedPlaceholder(word.slice(0, charIndex) || "");
        if (charIndex === 0) {
          direction = "forward";
          wordIndex = (wordIndex + 1) % brandNames.length;
          timeoutId = setTimeout(tick, 260);
          return;
        }
        timeoutId = setTimeout(tick, 45);
      };

      tick();
      return () => {
        active = false;
        clearTimeout(timeoutId);
      };
    }, [brandNames, isInputFocused, value]);

    return (
      <label className="relative block">
        <input
          type="text"
          placeholder=""
          aria-label="Ďîřóę áđĺíäó"
          value={value}
          onChange={(e) => onChange(e.target.value)}
          onFocus={() => setIsInputFocused(true)}
          onBlur={() => setIsInputFocused(false)}
          className="w-full rounded-2xl border border-blue-100/80 bg-white/90 px-4 pr-11 py-3 text-sm font-medium text-slate-800 shadow-inner shadow-blue-100/50 transition focus:border-blue-400 focus:outline-none focus:ring-2 focus:ring-blue-300"
          data-search="true"
        />
        {!value && !isInputFocused && (
          <span className="pointer-events-none absolute left-4 top-1/2 -translate-y-1/2 text-sm font-medium text-blue-400">
            {animatedPlaceholder}
          </span>
        )}
        <Search className="pointer-events-none absolute right-3 top-1/2 -translate-y-1/2 h-4 w-4 text-blue-400" />
      </label>
    );
  }
);

BrandSearchInput.displayName = "BrandSearchInput";

export default function BrandCarousel() {
  const [search, setSearch] = useState("");
  const brandNames = useMemo(
    () => brands.map((item) => item?.name ?? "").filter(Boolean),
    []
  );
  const filteredBrands = useMemo(
    () =>
      brands.filter((brand) =>
        brand.name.toLowerCase().includes(search.toLowerCase())
      ),
    [search]
  );

  return (
    <motion.section
      className="relative isolate w-full overflow-hidden px-4 py-12 sm:px-4 sm:py-16 lg:px-6 font-[Montserrat]"
      style={{
        backgroundImage: backgroundBase,
        backgroundSize: "220% 220%",
        backgroundPosition: "50% 42%",
        contain: "paint",
      }}
      initial={{ opacity: 0, y: 12 }}
      whileInView={{ opacity: 1, y: 0 }}
      viewport={viewportConfig}
      transition={{ duration: 0.28, ease: "easeOut" }}
    >
      {cardBackdrop}

      <div className="relative mx-auto w-full max-w-[1400px] space-y-7 sm:space-y-9">
        <div className="grid gap-4 md:grid-cols-[minmax(0,1fr)_320px] md:items-center">
          <div className="flex items-start gap-3 sm:items-center">
            <span className="inline-flex h-12 w-12 items-center justify-center rounded-2xl bg-gradient-to-br from-sky-50 via-blue-200 to-indigo-100 text-slate-900 shadow-[0_12px_26px_rgba(59,130,246,0.25)] ring-1 ring-blue-100">
              <Factory className="h-5 w-5" strokeWidth={2.2} />
            </span>
            <div className="flex flex-col">
              <h2 className="text-xl font-extrabold italic tracking-tight text-slate-900 sm:text-2xl">
                Âłäîěł âčđîáíčęč ŕâňîçŕď÷ŕńňčí
              </h2>
              <p className="mt-1 max-w-2xl text-sm leading-relaxed text-slate-600">
                Ďłäłáĺđłňü áđĺíä çŕ ńâîżě ńěŕęîě, âłäęđčéňĺ ęŕđňęó ňŕ äłçíŕéňĺńü
                ęëţ÷îâł îńîáëčâîńňł.
              </p>
            </div>
          </div>

          <div className="w-full">
            <BrandSearchInput
              value={search}
              onChange={setSearch}
              brandNames={brandNames}
            />
          </div>
        </div>

        <div className="brand-scroll relative flex w-full gap-5 overflow-x-auto overflow-y-visible pl-8 pr-6 py-5 sm:gap-6 sm:pl-9 sm:pr-7 sm:py-6 md:gap-7 md:pl-10 md:pr-8 snap-x snap-mandatory scroll-pl-8 sm:scroll-pl-9 md:scroll-pl-10">

          {filteredBrands.map((brand, idx) => (
            <div
              key={`${brand.name}-${idx}`}
              className="w-[200px] flex-shrink-0 snap-start sm:w-[220px] md:w-[245px] lg:w-[260px]"
            >
              <FlipCard brand={brand} />
            </div>
          ))}
        </div>
      </div>
    </motion.section>
  );
}

function FlipCard({ brand }: { brand: typeof brands[number] }) {
  const [showDetails, setShowDetails] = useState(false);
  const router = useRouter();

  const goToCatalog = () => {
    router.push(`/katalog?producer=${encodeURIComponent(brand.name)}`);
  };

  return (
      <motion.div
        className="relative h-full w-full overflow-hidden rounded-3xl border border-white/35 bg-white/10 shadow-[0_12px_26px_rgba(15,23,42,0.16)] ring-1 ring-white/20 backdrop-blur-sm min-h-[320px] sm:min-h-[360px]"
        initial={{ opacity: 0, y: 12 }}
        whileInView={{ opacity: 1, y: 0 }}
        viewport={{ once: false, amount: 0.35, margin: "0px 0px -8% 0px" }}
        transition={{ duration: 0.22, ease: "easeOut" }}
        onClick={goToCatalog}
        role="button"
        tabIndex={0}
        onKeyDown={(e) => {
          if (e.key === "Enter" || e.key === " ") {
            e.preventDefault();
            goToCatalog();
          }
        }}
      >
        <div className="pointer-events-none absolute inset-0">
          <div className="absolute inset-x-0 top-0 h-1/3 bg-gradient-to-b from-white/28 via-white/10 to-transparent" />
          <div className="absolute -left-6 bottom-6 h-20 w-20 rounded-full bg-blue-200/20 blur-2xl" />
          <div className="absolute right-[-12%] top-[-8%] h-24 w-24 rounded-full bg-cyan-200/22 blur-2xl" />
        </div>

        <div className="relative flex h-full w-full flex-col items-center justify-center p-6 gap-3">
          <div
            className={`transition-opacity duration-200 ${showDetails ? "opacity-0 pointer-events-none" : "opacity-100"}`}
          >
            <img
              src={brand.logo}
              alt={brand.name}
              className="max-h-24 w-full object-contain drop-shadow-[0_8px_18px_rgba(15,23,42,0.1)]"
              draggable={false}
              loading="lazy"
            />
          </div>

          <div
            className={`absolute inset-0 flex items-center justify-center px-6 text-center text-sm font-semibold leading-snug text-slate-700 sm:text-base transition-opacity duration-200 ${showDetails ? "opacity-100" : "opacity-0 pointer-events-none"}`}
          >
            <p className="max-h-[220px] overflow-y-auto leading-relaxed">{brand.description}</p>
          </div>

          <div className="absolute inset-x-0 bottom-2 flex items-center justify-center px-3">
            <div className="inline-flex items-center gap-2 rounded-full border border-white/55 bg-white/70 px-4 py-1.5 text-[11px] font-semibold uppercase tracking-[0.12em] text-slate-700 shadow-[0_10px_18px_rgba(15,23,42,0.12)]">
              Ďĺđĺăë˙ä ó ęŕňŕëîçł
            </div>
          </div>

          <button
            type="button"
            onClick={(e) => {
              e.stopPropagation();
              setShowDetails((prev) => !prev);
            }}
            aria-label="Äĺňŕëł"
            className="absolute right-4 top-4 inline-flex items-center gap-1.5 rounded-full border border-white/65 bg-white/90 px-3 py-1.5 text-[12px] font-semibold text-slate-900 shadow-[0_10px_20px_rgba(15,23,42,0.14)] transition hover:shadow-[0_12px_24px_rgba(15,23,42,0.18)] hover:bg-white"
          >
            <Info className="h-4 w-4" />
            <span className="tracking-tight">Äĺňŕëüíłřĺ</span>
          </button>
        </div>
      </motion.div>
  );
}


