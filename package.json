{
  "name": "partson",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "22.x",
    "npm": ">=10"
  },
  "scripts": {
    "clean:next": "node -e \"require('fs').rmSync('.next', { recursive: true, force: true })\"",
    "dev": "next dev --turbopack",
    "dev:clean": "npm run clean:next && next dev --turbopack",
    "dev:webpack": "next dev --webpack",
    "dev:all": "concurrently -k -n web,auth \"next dev --turbopack\" \"node server.js\"",
    "dev:turbo": "next dev --turbopack",
    "build": "npm run generate:seo-counts && next build",
    "build:full": "npm run generate:feed && npm run generate:seo-counts && next build",
    "generate:seo-counts": "tsx --require ./scripts/preload.cjs --env-file=.env.local scripts/generate-seo-counts.ts",
    "generate:feed": "tsx --require ./scripts/preload.cjs --env-file=.env.local scripts/generate-merchant-feed.ts",
    "merchant:feed:update": "bash scripts/update-merchant-feed.sh",
    "merchant:cron:install": "bash scripts/install-merchant-feed-cron.sh",
    "merchant:cron:list": "crontab -l | grep -A2 -B2 'partson merchant feed' || true",
    "start": "next start",
    "start:web": "next start -p 3000",
    "start:auth": "node server.js",
    "start:prod": "concurrently -k -n web,auth \"next start -p 3000\" \"node server.js\"",
    "lint": "eslint .",
    "pm2:start": "pm2 start ecosystem.config.js",
    "pm2:stop": "pm2 stop ecosystem.config.js",
    "pm2:restart": "pm2 restart ecosystem.config.js",
    "pm2:delete": "pm2 delete ecosystem.config.js",
    "pm2:logs": "pm2 logs --lines 100",
    "pm2:monit": "pm2 monit",
    "memory:monitor": "bash scripts/memory-monitor.sh"
  },
  "dependencies": {
    "@heroicons/react": "^2.2.0",
    "@radix-ui/react-slot": "^1.1.2",
    "@tailwindcss/postcss": "^4.1.7",
    "axios": "^1.8.4",
    "body-parser": "^2.2.0",
    "class-variance-authority": "^0.7.1",
    "classnames": "^2.5.1",
    "clsx": "^2.1.1",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "firebase": "^11.6.0",
    "firebase-admin": "^14.0.0",
    "framer-motion": "^12.5.0",
    "leaflet": "^1.9.4",
    "lodash": "^4.17.21",
    "lucide-react": "^0.482.0",
    "next": "^16.2.4",
    "postcss": "^8.5.15",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-feather": "^2.0.10",
    "react-icons": "^5.5.0",
    "react-intersection-observer": "^9.16.0",
    "react-leaflet": "^5.0.0",
    "react-virtuoso": "^4.18.1",
    "server-only": "^0.0.1",
    "soap": "^1.1.10",
    "socket.io-client": "^4.8.1",
    "tailwind-merge": "^3.1.0",
    "tailwind-scrollbar-hide": "^4.0.0",
    "tailwindcss": "^4.1.7",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@next/bundle-analyzer": "^16.2.9",
    "@types/leaflet": "^1.9.17",
    "@types/lodash": "^4.17.18",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^10.0.3",
    "critters": "^0.0.23",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tsx": "^4.22.4",
    "typescript": "^5"
  },
  "overrides": {
    "postcss": "$postcss",
    "google-auth-library": "^10.7.0",
    "@google-cloud/storage": {
      "gaxios": "^7.1.5",
      "retry-request": "^8.0.3",
      "teeny-request": "^10.1.3"
    }
  },
  "browserslist": [
    "Chrome >= 111",
    "Edge >= 111",
    "Firefox >= 115",
    "Safari >= 16.4",
    "iOS >= 16.4",
    "not op_mini all"
  ]
}
