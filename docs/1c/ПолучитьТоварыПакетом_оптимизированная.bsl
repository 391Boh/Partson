Функция ПолучитьТоварыПакетом(ТелоЗапросаJSON) Экспорт

    Перем Параметры;
    Перем Категория, Группа, Подгруппа, Наименование, Код, НомерПоКаталогу, Производитель;
    Перем ОписаниеПоиск, ПослеКода, КурсорЦены, ДанныеКурсораЦены;
    Перем ЦенаКурсора, КодКурсора, ЕстьКурсорЦены;
    Перем Лимит, ЛимитЗапроса;
    Перем ВключатьФотоBase64, ВключатьОписание, ПоискПроизводителя;
    Перем ВключатьОбщееКоличество, ТолькоСЦеной, ТолькоВНаличии;
    Перем ЦенаОт, ЦенаДо, СортировкаПоЦене, НаправлениеСортировкиПоЦене;
    Перем ИмяПаттерн, КодПаттерн, КаталогПаттерн, ПроизводительПаттерн, ОписаниеПаттерн;
    Перем НужнаЦенаДляФильтра, НужныОстаткиДляФильтра, НуженПолныйНабор;
    Перем БазовыеУсловия, ФинальныеУсловия, ВыражениеЦеныСортировки;
    Перем ПолеОписаниеКандидата;
    Перем ТекстКандидатов, ТекстАртикулов, ТекстЦен, ТекстОстатков;
    Перем ТекстСчета, ТекстТоваров;
    Перем МенеджерВременныхТаблиц, ЗапросПодготовки, ЗапросСчета, ЗапросТоваров;
    Перем РезультатПодготовки, РезультатСчета, РезультатТоваров, ВыборкаКол, Выборка;
    Перем ОбщееКоличество, ДатаОстатков;
    Перем Товары, ТоварJSON, КодТовара, КоличествоПолучено;
    Перем ЕстьЕще, СледующийКурсор, СледующаяЦенаСортировки;
    Перем СтруктураКурсора, ФотоДанные, ТекстОшибки, Результат;

    // ---------------------------------------------------------------------
    // 1. Параметры запроса
    // ---------------------------------------------------------------------

    Попытка
        Параметры = ПрочитатьJSONВСтруктуру(ТелоЗапросаJSON);
    Исключение
        ТекстОшибки = ОписаниеОшибки();
        Результат = JSONОшибкаСтрокой("Неверный JSON", ТекстОшибки, "");
        Возврат Результат;
    КонецПопытки;

    Если ТипЗнч(Параметры) <> Тип("Структура") Тогда
        Возврат JSONОшибкаСтрокой("JSON должен быть структурой", "", "");
    КонецЕсли;

    Категория       = ПолучитьСтрокуПараметра(Параметры, "Категория");
    Группа          = ПолучитьСтрокуПараметра(Параметры, "Группа");
    Подгруппа       = ПолучитьСтрокуПараметра(Параметры, "Подгруппа");
    Наименование    = ПолучитьСтрокуПараметра(Параметры, "Наименование");
    Код             = ПолучитьСтрокуПараметра(Параметры, "Код");
    НомерПоКаталогу = ПолучитьСтрокуПараметра(Параметры, "НомерПоКаталогу");
    Производитель   = ПолучитьСтрокуПараметра(Параметры, "ПроизводительНаименование");
    ПослеКода       = ПолучитьСтрокуПараметра(Параметры, "ПослеКода");

    ОписаниеПоиск = ПолучитьСтрокуПараметра(Параметры, "Описание");
    Если Не ЗначениеЗаполнено(ОписаниеПоиск) Тогда
        ОписаниеПоиск = ПолучитьСтрокуПараметра(Параметры, "Опис");
    КонецЕсли;
    Если Не ЗначениеЗаполнено(ОписаниеПоиск) Тогда
        ОписаниеПоиск = ПолучитьСтрокуПараметра(Параметры, "Description");
    КонецЕсли;
    Если Не ЗначениеЗаполнено(ОписаниеПоиск) Тогда
        ОписаниеПоиск = ПолучитьСтрокуПараметра(Параметры, "description");
    КонецЕсли;

    Лимит = ПолучитьЧислоПараметра(Параметры, "Лимит", 50);
    Если Лимит < 1 Тогда
        Лимит = 50;
    КонецЕсли;
    Если Лимит > 500 Тогда
        Лимит = 500;
    КонецЕсли;
    Лимит = Цел(Лимит);
    ЛимитЗапроса = Лимит + 1;

    ВключатьФотоBase64 = ПолучитьБулевоПараметра(
        Параметры, "ВключатьФотоBase64", Ложь);
    ВключатьОписание = ПолучитьБулевоПараметра(
        Параметры, "ВключатьОписание", Ложь);
    ПоискПроизводителя = ПолучитьБулевоПараметра(
        Параметры, "ПоискПроизводителя", Ложь);
    ТолькоСЦеной = ПолучитьБулевоПараметра(
        Параметры, "ТолькоСЦеной", Ложь);
    ТолькоВНаличии = ПолучитьБулевоПараметра(
        Параметры, "ТолькоВНаличии", Ложь);

    ЦенаОт = ПолучитьЧислоПараметра(Параметры, "ЦенаОт", -1);
    Если ЦенаОт < 0 Тогда
        ЦенаОт = ПолучитьЧислоПараметра(Параметры, "ЦінаВід", -1);
    КонецЕсли;

    ЦенаДо = ПолучитьЧислоПараметра(Параметры, "ЦенаДо", -1);
    Если ЦенаДо < 0 Тогда
        ЦенаДо = ПолучитьЧислоПараметра(Параметры, "ЦінаДо", -1);
    КонецЕсли;

    Если ЦенаОт >= 0 И ЦенаДо >= 0 И ЦенаОт > ЦенаДо Тогда
        Возврат JSONОшибкаСтрокой("Неверный диапазон цен", "ЦенаОт не может быть больше ЦенаДо", "");
    КонецЕсли;

    СортировкаПоЦене = ВРег(
        ПолучитьСтрокуПараметра(Параметры, "СортировкаПоЦене"));
    НаправлениеСортировкиПоЦене = "";

    Если СортировкаПоЦене = "ASC" ИЛИ СортировкаПоЦене = "ВОЗР" Тогда
        НаправлениеСортировкиПоЦене = "ВОЗР";
    ИначеЕсли СортировкаПоЦене = "DESC" ИЛИ СортировкаПоЦене = "УБЫВ" Тогда
        НаправлениеСортировкиПоЦене = "УБЫВ";
    КонецЕсли;

    // При ценовой сортировке непрозрачный JSON-курсор можно передать как
    // КурсорЦены, cursor или (для совместимости с текущим Next.js) ПослеКода.
    КурсорЦены = ПолучитьСтрокуПараметра(Параметры, "КурсорЦены");
    Если Не ЗначениеЗаполнено(КурсорЦены) Тогда
        КурсорЦены = ПолучитьСтрокуПараметра(Параметры, "cursor");
    КонецЕсли;

    Если ЗначениеЗаполнено(НаправлениеСортировкиПоЦене)
        И Не ЗначениеЗаполнено(КурсорЦены)
        И Лев(СокрЛП(ПослеКода), 1) = "{" Тогда
        КурсорЦены = ПослеКода;
        ПослеКода = "";
    КонецЕсли;

    ЕстьКурсорЦены = Ложь;
    ЦенаКурсора = 0;
    КодКурсора = "";

    Если ЗначениеЗаполнено(КурсорЦены) Тогда
        Попытка
            ДанныеКурсораЦены = ПрочитатьJSONВСтруктуру(КурсорЦены);
            Если ТипЗнч(ДанныеКурсораЦены) <> Тип("Структура") Тогда
                Возврат JSONОшибкаСтрокой("Неверный курсор цены", "Курсор должен быть JSON-структурой", "");
            КонецЕсли;

            ЦенаКурсора = ПолучитьЧислоПараметра(
                ДанныеКурсораЦены, "price", -999999999999);
            КодКурсора = ПолучитьСтрокуПараметра(
                ДанныеКурсораЦены, "code");

            Если ЦенаКурсора < -1 ИЛИ Не ЗначениеЗаполнено(КодКурсора) Тогда
                Возврат JSONОшибкаСтрокой("Неверный курсор цены", "В курсоре отсутствуют price или code", "");
            КонецЕсли;

            ЕстьКурсорЦены = Истина;
        Исключение
            ТекстОшибки = ОписаниеОшибки();
            Результат = JSONОшибкаСтрокой("Неверный курсор цены", ТекстОшибки, "");
            Возврат Результат;
        КонецПопытки;
    КонецЕсли;

    ВключатьОбщееКоличество = ПолучитьБулевоПараметра(
        Параметры,
        "ВключатьОбщееКоличество",
        Не ЗначениеЗаполнено(ПослеКода) И Не ЕстьКурсорЦены);

    // ---------------------------------------------------------------------
    // 2. Условия дешевого отбора по номенклатуре
    // ---------------------------------------------------------------------

    ИмяПаттерн = Неопределено;
    КодПаттерн = Неопределено;
    КаталогПаттерн = Неопределено;
    ПроизводительПаттерн = Неопределено;
    ОписаниеПаттерн = Неопределено;

    Если ЗначениеЗаполнено(Наименование) Тогда
        ИмяПаттерн = "%" + Наименование + "%";
    КонецЕсли;
    Если ЗначениеЗаполнено(Код) Тогда
        КодПаттерн = Код + "%";
    КонецЕсли;
    Если ЗначениеЗаполнено(НомерПоКаталогу) Тогда
        КаталогПаттерн = НомерПоКаталогу + "%";
    КонецЕсли;
    Если ЗначениеЗаполнено(Производитель) И ПоискПроизводителя Тогда
        ПроизводительПаттерн = Производитель + "%";
    КонецЕсли;
    Если ЗначениеЗаполнено(ОписаниеПоиск) Тогда
        ОписаниеПаттерн = "%" + ОписаниеПоиск + "%";
    КонецЕсли;

    БазовыеУсловия = "
|   НЕ Ном.ПометкаУдаления
|   И Ном.ЭтоГруппа = ЛОЖЬ";

    Если ЗначениеЗаполнено(Категория) Тогда
        БазовыеУсловия = БазовыеУсловия + "
|   И Ном.Родитель.Родитель.Родитель.Наименование = &Категория";
    КонецЕсли;
    Если ЗначениеЗаполнено(Группа) Тогда
        БазовыеУсловия = БазовыеУсловия + "
|   И Ном.Родитель.Родитель.Наименование = &Группа";
    КонецЕсли;
    Если ЗначениеЗаполнено(Подгруппа) Тогда
        БазовыеУсловия = БазовыеУсловия + "
|   И Ном.Родитель.Наименование = &Подгруппа";
    КонецЕсли;
    Если ИмяПаттерн <> Неопределено Тогда
        БазовыеУсловия = БазовыеУсловия + "
|   И Ном.Наименование ПОДОБНО &ИмяПаттерн";
    КонецЕсли;
    Если КодПаттерн <> Неопределено Тогда
        БазовыеУсловия = БазовыеУсловия + "
|   И Ном.Код ПОДОБНО &КодПаттерн";
    КонецЕсли;
    Если КаталогПаттерн <> Неопределено Тогда
        БазовыеУсловия = БазовыеУсловия + "
|   И Ном.ор_НомерПоКаталогу ПОДОБНО &КаталогПаттерн";
    КонецЕсли;
    Если ЗначениеЗаполнено(Производитель) И Не ПоискПроизводителя Тогда
        БазовыеУсловия = БазовыеУсловия + "
|   И Ном.ор_Производитель.Наименование = &Производитель";
    ИначеЕсли ПроизводительПаттерн <> Неопределено Тогда
        БазовыеУсловия = БазовыеУсловия + "
|   И Ном.ор_Производитель.Наименование ПОДОБНО &ПроизводительПаттерн";
    КонецЕсли;
    Если ОписаниеПаттерн <> Неопределено Тогда
        БазовыеУсловия = БазовыеУсловия + "
|   И Ном.Описание ПОДОБНО &ОписаниеПаттерн";
    КонецЕсли;

    НужнаЦенаДляФильтра = ТолькоСЦеной ИЛИ ЦенаОт >= 0 ИЛИ ЦенаДо >= 0;
    НужныОстаткиДляФильтра = ТолькоВНаличии;
    НуженПолныйНабор = НужнаЦенаДляФильтра
        ИЛИ НужныОстаткиДляФильтра
        ИЛИ ЗначениеЗаполнено(НаправлениеСортировкиПоЦене);

    // ---------------------------------------------------------------------
    // 3. Временная таблица кандидатов
    // ---------------------------------------------------------------------

    Если ВключатьОписание Тогда
        ПолеОписаниеКандидата = "Ном.Описание";
    Иначе
        ПолеОписаниеКандидата = "&ПустаяСтрока";
    КонецЕсли;

    Если НуженПолныйНабор Тогда
        ТекстКандидатов =
"ВЫБРАТЬ
|   Ном.Ссылка КАК Ссылка,
|   Ном.Код КАК Код,
|   Ном.Наименование КАК Наименование,
|   " + ПолеОписаниеКандидата + " КАК Описание,
|   Ном.ор_НомерПоКаталогу КАК НомерПоКаталогу,
|   Ном.ор_Производитель.Наименование КАК ПроизводительНаименование,
|   Ном.Родитель.Наименование КАК Подгруппа,
|   Ном.Родитель.Родитель.Наименование КАК Группа,
|   Ном.Родитель.Родитель.Родитель.Наименование КАК Категория,
|   Ном.ФайлКартинки КАК ФайлКартинки
|ПОМЕСТИТЬ ВТКандидаты
|ИЗ
|   Справочник.Номенклатура КАК Ном
|ГДЕ" + БазовыеУсловия + "
|ИНДЕКСИРОВАТЬ ПО
|   Ссылка";
    Иначе
        ТекстКандидатов =
"ВЫБРАТЬ ПЕРВЫЕ " + Формат(ЛимитЗапроса, "ЧГ=0") + "
|   Ном.Ссылка КАК Ссылка,
|   Ном.Код КАК Код,
|   Ном.Наименование КАК Наименование,
|   " + ПолеОписаниеКандидата + " КАК Описание,
|   Ном.ор_НомерПоКаталогу КАК НомерПоКаталогу,
|   Ном.ор_Производитель.Наименование КАК ПроизводительНаименование,
|   Ном.Родитель.Наименование КАК Подгруппа,
|   Ном.Родитель.Родитель.Наименование КАК Группа,
|   Ном.Родитель.Родитель.Родитель.Наименование КАК Категория,
|   Ном.ФайлКартинки КАК ФайлКартинки
|ПОМЕСТИТЬ ВТКандидаты
|ИЗ
|   Справочник.Номенклатура КАК Ном
|ГДЕ" + БазовыеУсловия;

        Если ЗначениеЗаполнено(ПослеКода) Тогда
            ТекстКандидатов = ТекстКандидатов + "
|   И Ном.Код > &ПослеКода";
        КонецЕсли;

        ТекстКандидатов = ТекстКандидатов + "
|ИНДЕКСИРОВАТЬ ПО
|   Ссылка
|УПОРЯДОЧИТЬ ПО
|   Ном.Код ВОЗР";
    КонецЕсли;

    // Уникальный список артикулов устраняет умножение строк в соединении цен.
    ТекстАртикулов =
"ВЫБРАТЬ РАЗЛИЧНЫЕ
|   Кандидаты.НомерПоКаталогу КАК Артикул
|ПОМЕСТИТЬ ВТАртикулы
|ИЗ
|   ВТКандидаты КАК Кандидаты
|ГДЕ
|   Кандидаты.НомерПоКаталогу <> &ПустаяСтрока
|ИНДЕКСИРОВАТЬ ПО
|   Артикул";

    // Цена агрегируется только для уже отобранных артикулов.
    ТекстЦен =
"ВЫБРАТЬ
|   Ц.Наименование КАК Артикул,
|   МАКСИМУМ(Ц.ЦінаПрод) КАК ЦінаПрод
|ПОМЕСТИТЬ ВТЦены
|ИЗ
|   Справочник.Ціна КАК Ц
|       ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТАртикулы КАК Артикулы
|       ПО Ц.Наименование = Артикулы.Артикул
|ГДЕ
|   НЕ Ц.ПометкаУдаления
|СГРУППИРОВАТЬ ПО
|   Ц.Наименование
|ИНДЕКСИРОВАТЬ ПО
|   Артикул";

    // Остатки агрегируются только для уже отобранных ссылок номенклатуры.
    ТекстОстатков =
"ВЫБРАТЬ
|   Ост.Номенклатура КАК Номенклатура,
|   СУММА(Ост.КоличествоОстаток) КАК Количество
|ПОМЕСТИТЬ ВТОстатки
|ИЗ
|   РегистрНакопления.ТоварыНаСкладах.Остатки(&ДатаОстатков) КАК Ост
|       ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТКандидаты КАК Кандидаты
|       ПО Ост.Номенклатура = Кандидаты.Ссылка
|СГРУППИРОВАТЬ ПО
|   Ост.Номенклатура
|ИНДЕКСИРОВАТЬ ПО
|   Номенклатура";

    МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;
    ЗапросПодготовки = Новый Запрос;
    ЗапросПодготовки.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
    ДатаОстатков = ТекущаяДата();

    ЗапросПодготовки.УстановитьПараметр("ДатаОстатков", ДатаОстатков);
    ЗапросПодготовки.УстановитьПараметр("ПустаяСтрока", "");

    Если ЗначениеЗаполнено(Категория) Тогда
        ЗапросПодготовки.УстановитьПараметр("Категория", Категория);
    КонецЕсли;
    Если ЗначениеЗаполнено(Группа) Тогда
        ЗапросПодготовки.УстановитьПараметр("Группа", Группа);
    КонецЕсли;
    Если ЗначениеЗаполнено(Подгруппа) Тогда
        ЗапросПодготовки.УстановитьПараметр("Подгруппа", Подгруппа);
    КонецЕсли;
    Если ИмяПаттерн <> Неопределено Тогда
        ЗапросПодготовки.УстановитьПараметр("ИмяПаттерн", ИмяПаттерн);
    КонецЕсли;
    Если КодПаттерн <> Неопределено Тогда
        ЗапросПодготовки.УстановитьПараметр("КодПаттерн", КодПаттерн);
    КонецЕсли;
    Если КаталогПаттерн <> Неопределено Тогда
        ЗапросПодготовки.УстановитьПараметр("КаталогПаттерн", КаталогПаттерн);
    КонецЕсли;
    Если ЗначениеЗаполнено(Производитель) И Не ПоискПроизводителя Тогда
        ЗапросПодготовки.УстановитьПараметр(
            "Производитель", Производитель);
    ИначеЕсли ПроизводительПаттерн <> Неопределено Тогда
        ЗапросПодготовки.УстановитьПараметр(
            "ПроизводительПаттерн", ПроизводительПаттерн);
    КонецЕсли;
    Если ОписаниеПаттерн <> Неопределено Тогда
        ЗапросПодготовки.УстановитьПараметр("ОписаниеПаттерн", ОписаниеПаттерн);
    КонецЕсли;
    Если Не НуженПолныйНабор И ЗначениеЗаполнено(ПослеКода) Тогда
        ЗапросПодготовки.УстановитьПараметр("ПослеКода", ПослеКода);
    КонецЕсли;

    ЗапросПодготовки.Текст = ТекстКандидатов + "
|;
|" + ТекстАртикулов + "
|;
|" + ТекстЦен + "
|;
|" + ТекстОстатков;

    Попытка
        РезультатПодготовки = ЗапросПодготовки.Выполнить();
    Исключение
        ТекстОшибки = ОписаниеОшибки();
        Результат = JSONОшибкаСтрокой("Ошибка подготовки каталога", ТекстОшибки, "");
        Возврат Результат;
    КонецПопытки;

    // ---------------------------------------------------------------------
    // 4. Условия по цене и остаткам после локальных агрегатов
    // ---------------------------------------------------------------------

    ФинальныеУсловия = "
|   1 = 1";

    Если ТолькоСЦеной Тогда
        ФинальныеУсловия = ФинальныеУсловия + "
|   И ЕСТЬNULL(Цены.ЦінаПрод, 0) > 0";
    КонецЕсли;
    Если ТолькоВНаличии Тогда
        ФинальныеУсловия = ФинальныеУсловия + "
|   И ЕСТЬNULL(Остатки.Количество, 0) > 0";
    КонецЕсли;
    Если ЦенаОт >= 0 Тогда
        ФинальныеУсловия = ФинальныеУсловия + "
|   И ЕСТЬNULL(Цены.ЦінаПрод, 0) >= &ЦенаОт";
    КонецЕсли;
    Если ЦенаДо >= 0 Тогда
        ФинальныеУсловия = ФинальныеУсловия + "
|   И ЕСТЬNULL(Цены.ЦінаПрод, 0) <= &ЦенаДо";
    КонецЕсли;

    // ---------------------------------------------------------------------
    // 5. Общее количество. На cursor-страницах запрос можно пропустить.
    // ---------------------------------------------------------------------

    ОбщееКоличество = -1;

    Если ВключатьОбщееКоличество Тогда
        ЗапросСчета = Новый Запрос;
        ЗапросСчета.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;

        Если НуженПолныйНабор Тогда
            ТекстСчета =
"ВЫБРАТЬ
|   КОЛИЧЕСТВО(Кандидаты.Ссылка) КАК Количество
|ИЗ
|   ВТКандидаты КАК Кандидаты
|       ЛЕВОЕ СОЕДИНЕНИЕ ВТЦены КАК Цены
|       ПО Цены.Артикул = Кандидаты.НомерПоКаталогу
|       ЛЕВОЕ СОЕДИНЕНИЕ ВТОстатки КАК Остатки
|       ПО Остатки.Номенклатура = Кандидаты.Ссылка
|ГДЕ" + ФинальныеУсловия;

            Если ЦенаОт >= 0 Тогда
                ЗапросСчета.УстановитьПараметр("ЦенаОт", ЦенаОт);
            КонецЕсли;
            Если ЦенаДо >= 0 Тогда
                ЗапросСчета.УстановитьПараметр("ЦенаДо", ЦенаДо);
            КонецЕсли;
        Иначе
            ТекстСчета =
"ВЫБРАТЬ
|   КОЛИЧЕСТВО(Ном.Ссылка) КАК Количество
|ИЗ
|   Справочник.Номенклатура КАК Ном
|ГДЕ" + БазовыеУсловия;

            Если ЗначениеЗаполнено(Категория) Тогда
                ЗапросСчета.УстановитьПараметр("Категория", Категория);
            КонецЕсли;
            Если ЗначениеЗаполнено(Группа) Тогда
                ЗапросСчета.УстановитьПараметр("Группа", Группа);
            КонецЕсли;
            Если ЗначениеЗаполнено(Подгруппа) Тогда
                ЗапросСчета.УстановитьПараметр("Подгруппа", Подгруппа);
            КонецЕсли;
            Если ИмяПаттерн <> Неопределено Тогда
                ЗапросСчета.УстановитьПараметр("ИмяПаттерн", ИмяПаттерн);
            КонецЕсли;
            Если КодПаттерн <> Неопределено Тогда
                ЗапросСчета.УстановитьПараметр("КодПаттерн", КодПаттерн);
            КонецЕсли;
            Если КаталогПаттерн <> Неопределено Тогда
                ЗапросСчета.УстановитьПараметр("КаталогПаттерн", КаталогПаттерн);
            КонецЕсли;
            Если ЗначениеЗаполнено(Производитель) И Не ПоискПроизводителя Тогда
                ЗапросСчета.УстановитьПараметр(
                    "Производитель", Производитель);
            ИначеЕсли ПроизводительПаттерн <> Неопределено Тогда
                ЗапросСчета.УстановитьПараметр(
                    "ПроизводительПаттерн", ПроизводительПаттерн);
            КонецЕсли;
            Если ОписаниеПаттерн <> Неопределено Тогда
                ЗапросСчета.УстановитьПараметр("ОписаниеПаттерн", ОписаниеПаттерн);
            КонецЕсли;
        КонецЕсли;

        ЗапросСчета.Текст = ТекстСчета;

        Попытка
            РезультатСчета = ЗапросСчета.Выполнить();
            ВыборкаКол = РезультатСчета.Выбрать();
            Если ВыборкаКол.Следующий() Тогда
                ОбщееКоличество = ВыборкаКол.Количество;
            Иначе
                ОбщееКоличество = 0;
            КонецЕсли;
        Исключение
            ТекстОшибки = ОписаниеОшибки();
            Результат = JSONОшибкаСтрокой("Ошибка подсчета товаров", ТекстОшибки, "");
            Возврат Результат;
        КонецПопытки;
    КонецЕсли;

    // ---------------------------------------------------------------------
    // 6. Финальная страница товаров
    // ---------------------------------------------------------------------

    Если НаправлениеСортировкиПоЦене = "ВОЗР" Тогда
        // Товары без публичной цены всегда идут после товаров с ценой.
        ВыражениеЦеныСортировки =
            "ВЫБОР КОГДА ЕСТЬNULL(Цены.ЦінаПрод, 0) > 0 "
            + "ТОГДА ЕСТЬNULL(Цены.ЦінаПрод, 0) "
            + "ИНАЧЕ 999999999999 КОНЕЦ";
    ИначеЕсли НаправлениеСортировкиПоЦене = "УБЫВ" Тогда
        ВыражениеЦеныСортировки =
            "ВЫБОР КОГДА ЕСТЬNULL(Цены.ЦінаПрод, 0) > 0 "
            + "ТОГДА ЕСТЬNULL(Цены.ЦінаПрод, 0) "
            + "ИНАЧЕ -1 КОНЕЦ";
    Иначе
        ВыражениеЦеныСортировки = "ЕСТЬNULL(Цены.ЦінаПрод, 0)";
    КонецЕсли;

    ТекстТоваров =
"ВЫБРАТЬ ПЕРВЫЕ " + Формат(ЛимитЗапроса, "ЧГ=0") + "
|   Кандидаты.Ссылка КАК Ссылка,
|   Кандидаты.Код КАК Код,
|   Кандидаты.Наименование КАК Наименование,
|   Кандидаты.Описание КАК Описание,
|   Кандидаты.НомерПоКаталогу КАК НомерПоКаталогу,
|   Кандидаты.ПроизводительНаименование КАК ПроизводительНаименование,
|   Кандидаты.Подгруппа КАК Подгруппа,
|   Кандидаты.Группа КАК Группа,
|   Кандидаты.Категория КАК Категория,
|   ЕСТЬNULL(Остатки.Количество, 0) КАК Количество,
|   ВЫБОР
|       КОГДА ЕСТЬNULL(Остатки.Количество, 0) > 0 ТОГДА ИСТИНА
|       ИНАЧЕ ЛОЖЬ
|   КОНЕЦ КАК ВНаличии,
|   ЕСТЬNULL(Цены.ЦінаПрод, 0) КАК ЦінаПрод,
|   ВЫБОР
|       КОГДА ЕСТЬNULL(Цены.ЦінаПрод, 0) > 0 ТОГДА ИСТИНА
|       ИНАЧЕ ЛОЖЬ
|   КОНЕЦ КАК ЕстьЦена,
|   Кандидаты.ФайлКартинки КАК ФайлКартинки,
|   " + ВыражениеЦеныСортировки + " КАК ЦенаСортировки
|ИЗ
|   ВТКандидаты КАК Кандидаты
|       ЛЕВОЕ СОЕДИНЕНИЕ ВТЦены КАК Цены
|       ПО Цены.Артикул = Кандидаты.НомерПоКаталогу
|       ЛЕВОЕ СОЕДИНЕНИЕ ВТОстатки КАК Остатки
|       ПО Остатки.Номенклатура = Кандидаты.Ссылка
|ГДЕ" + ФинальныеУсловия;

    Если ЕстьКурсорЦены И ЗначениеЗаполнено(НаправлениеСортировкиПоЦене) Тогда
        Если НаправлениеСортировкиПоЦене = "ВОЗР" Тогда
            ТекстТоваров = ТекстТоваров + "
|   И (
|       " + ВыражениеЦеныСортировки + " > &ЦенаКурсора
|       ИЛИ (
|           " + ВыражениеЦеныСортировки + " = &ЦенаКурсора
|           И Кандидаты.Код > &КодКурсора
|       )
|   )";
        Иначе
            ТекстТоваров = ТекстТоваров + "
|   И (
|       " + ВыражениеЦеныСортировки + " < &ЦенаКурсора
|       ИЛИ (
|           " + ВыражениеЦеныСортировки + " = &ЦенаКурсора
|           И Кандидаты.Код > &КодКурсора
|       )
|   )";
        КонецЕсли;
    ИначеЕсли ЗначениеЗаполнено(ПослеКода)
        И Не ЗначениеЗаполнено(НаправлениеСортировкиПоЦене) Тогда
        ТекстТоваров = ТекстТоваров + "
|   И Кандидаты.Код > &ПослеКода";
    КонецЕсли;

    Если ЗначениеЗаполнено(НаправлениеСортировкиПоЦене) Тогда
        ТекстТоваров = ТекстТоваров + "
|УПОРЯДОЧИТЬ ПО
|   ЦенаСортировки " + НаправлениеСортировкиПоЦене + ",
|   Кандидаты.Код ВОЗР";
    Иначе
        ТекстТоваров = ТекстТоваров + "
|УПОРЯДОЧИТЬ ПО
|   Кандидаты.Код ВОЗР";
    КонецЕсли;

    ЗапросТоваров = Новый Запрос;
    ЗапросТоваров.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
    ЗапросТоваров.Текст = ТекстТоваров;

    Если ЦенаОт >= 0 Тогда
        ЗапросТоваров.УстановитьПараметр("ЦенаОт", ЦенаОт);
    КонецЕсли;
    Если ЦенаДо >= 0 Тогда
        ЗапросТоваров.УстановитьПараметр("ЦенаДо", ЦенаДо);
    КонецЕсли;
    Если ЕстьКурсорЦены И ЗначениеЗаполнено(НаправлениеСортировкиПоЦене) Тогда
        ЗапросТоваров.УстановитьПараметр("ЦенаКурсора", ЦенаКурсора);
        ЗапросТоваров.УстановитьПараметр("КодКурсора", КодКурсора);
    ИначеЕсли ЗначениеЗаполнено(ПослеКода)
        И Не ЗначениеЗаполнено(НаправлениеСортировкиПоЦене) Тогда
        ЗапросТоваров.УстановитьПараметр("ПослеКода", ПослеКода);
    КонецЕсли;

    Попытка
        РезультатТоваров = ЗапросТоваров.Выполнить();
        Выборка = РезультатТоваров.Выбрать();
    Исключение
        ТекстОшибки = ОписаниеОшибки();
        Результат = JSONОшибкаСтрокой("Ошибка получения товаров", ТекстОшибки, "");
        Возврат Результат;
    КонецПопытки;

    // ---------------------------------------------------------------------
    // 7. JSON без чтения изображений, если Base64 явно не запрошен
    // ---------------------------------------------------------------------

    Товары = Новый Массив;
    КоличествоПолучено = 0;
    ЕстьЕще = Ложь;
    СледующийКурсор = "";
    СледующаяЦенаСортировки = 0;

    Пока Выборка.Следующий() Цикл
        Если КоличествоПолучено >= Лимит Тогда
            ЕстьЕще = Истина;
            Прервать;
        КонецЕсли;

        КодТовара = СокрЛП(Строка(Выборка.Код));

        ТоварJSON = Новый Структура;
        ТоварJSON.Вставить("ID", Строка(Выборка.Ссылка));
        ТоварJSON.Вставить("Код", КодТовара);
        ТоварJSON.Вставить(
            "Наименование", СокрЛП(Строка(Выборка.Наименование)));
        ТоварJSON.Вставить(
            "НомерПоКаталогу", СокрЛП(Строка(Выборка.НомерПоКаталогу)));
        ТоварJSON.Вставить(
            "ПроизводительНаименование",
            СокрЛП(Строка(Выборка.ПроизводительНаименование)));
        ТоварJSON.Вставить("Подгруппа", СокрЛП(Строка(Выборка.Подгруппа)));
        ТоварJSON.Вставить("Группа", СокрЛП(Строка(Выборка.Группа)));
        ТоварJSON.Вставить("Категория", СокрЛП(Строка(Выборка.Категория)));
        ТоварJSON.Вставить("Количество", Выборка.Количество);
        ТоварJSON.Вставить("ВНаличии", Выборка.ВНаличии);
        ТоварJSON.Вставить("ЦінаПрод", Выборка.ЦінаПрод);
        ТоварJSON.Вставить("ЕстьЦена", Выборка.ЕстьЦена);
        ТоварJSON.Вставить(
            "ЕстьФото", ЗначениеЗаполнено(Выборка.ФайлКартинки));

        Если ВключатьОписание Тогда
            ТоварJSON.Вставить(
                "Описание", СокрЛП(Строка(Выборка.Описание)));
        КонецЕсли;

        Если ВключатьФотоBase64
            И ЗначениеЗаполнено(Выборка.ФайлКартинки) Тогда
            Попытка
                ФотоДанные = ПолучитьФотоBase64ПоСсылкеФайла(
                    Выборка.ФайлКартинки);
                ТоварJSON.Вставить(
                    "ФотоИмяФайла",
                    ПолучитьСтрокуПараметра(ФотоДанные, "file_name"));
                ТоварJSON.Вставить(
                    "ФотоBase64",
                    ПолучитьСтрокуПараметра(ФотоДанные, "image_base64"));
                ТоварJSON.Вставить(
                    "ФотоОшибка",
                    ПолучитьСтрокуПараметра(ФотоДанные, "error_message"));
            Исключение
                ТоварJSON.Вставить("ФотоОшибка", ОписаниеОшибки());
            КонецПопытки;
        КонецЕсли;

        Товары.Добавить(ТоварJSON);
        КоличествоПолучено = КоличествоПолучено + 1;
        // Для cursor сохраняем значение поля без форматирования. Отображаемый
        // Код можно обрезать, но keyset должен сравнивать то же значение,
        // которое участвовало в сортировке запроса.
        СледующийКурсор = Строка(Выборка.Код);
        СледующаяЦенаСортировки = Выборка.ЦенаСортировки;
    КонецЦикла;

    // ---------------------------------------------------------------------
    // 8. Ответ
    // ---------------------------------------------------------------------

    Результат = Новый Структура;
    Результат.Вставить("success", Истина);
    Результат.Вставить("count", Товары.Количество());
    Результат.Вставить("total_count", ОбщееКоличество);
    Результат.Вставить("items", Товары);
    Результат.Вставить("has_more", ЕстьЕще);

    Если ЗначениеЗаполнено(НаправлениеСортировкиПоЦене) Тогда
        Результат.Вставить("cursor_mode", "price_code_v1");

        Если ЕстьЕще И ЗначениеЗаполнено(СледующийКурсор) Тогда
            СтруктураКурсора = Новый Структура;
            СтруктураКурсора.Вставить("price", СледующаяЦенаСортировки);
            СтруктураКурсора.Вставить("code", СледующийКурсор);
            Результат.Вставить(
                "next_cursor", СериализоватьJSON(СтруктураКурсора));
        Иначе
            Результат.Вставить("next_cursor", "");
        КонецЕсли;
    Иначе
        Результат.Вставить("cursor_mode", "code_v1");

        Если ЕстьЕще И ЗначениеЗаполнено(СледующийКурсор) Тогда
            Результат.Вставить("next_cursor", СледующийКурсор);
        Иначе
            Результат.Вставить("next_cursor", "");
        КонецЕсли;
    КонецЕсли;

    Возврат СериализоватьJSON(Результат);

КонецФункции
